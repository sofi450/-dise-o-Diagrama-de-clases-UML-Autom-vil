package automovil;

public class Motor {
	// Atributo de instancia
	private String tipo;

	/**
	 * @param tipo atributo local
	 */
	public Motor(String tipo) {
		super();
		this.tipo = tipo;
	}

	public String getTipo() {
		return tipo;
	}

	public void setTipo(String tipo) {
		this.tipo = tipo;
	}

	@Override
	public String toString() {
		return " Tipo " + this.tipo;
	}
}
